import std.*;

public void foo(barrier b) {
    b.sync();
    println("done sync'ing foo");
}

public void bar(barrier b) {
    b.sync();
    println("done sync'ing bar");
}

public void baz(barrier b) {
    b.sync();
    println("done sync'ing baz");
}

